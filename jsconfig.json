{
  "compilerOptions": {
	   "baseUrl": ".",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"]
    },
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true

  },
  "include": ["src/**/*.js", "src/**/*.svelte"]
}
